{
  "name": "simulator-mcp",
  "version": "1.0.0",
  "description": "Model Context Protocol server that lets AI assistants drive the iOS Simulator — screenshots, taps, swipes, deep links, appearance and status-bar control.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ios",
    "simulator",
    "simctl",
    "xcode",
    "claude",
    "cursor",
    "ai",
    "screenshot",
    "automation"
  ],
  "homepage": "https://github.com/miccou/ios-simulator-mcp#readme",
  "bugs": {
    "url": "https://github.com/miccou/ios-simulator-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miccou/ios-simulator-mcp.git"
  },
  "license": "MIT",
  "author": "Michael Cousins",
  "type": "module",
  "bin": {
    "simulator-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "typescript": "^5.7.0"
  }
}
